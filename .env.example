# ── PageRAG Configuration ─────────────────────────────────────────────────────

# 1. LLM Provider — Ollama (local / Docker container)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
# Other popular models: mistral:latest, phi3:mini, llama3.1:8b, gemma2:9b

# 2. Database Configurations
# Optional. Falls back to a local SQLite database (pagerag.db) automatically.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pagerag

# 3. Search Engine Configurations
# Optional. Falls back to local BM25 engine automatically if not set.
# ELASTICSEARCH_URL=http://localhost:9200
